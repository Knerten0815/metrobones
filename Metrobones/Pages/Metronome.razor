@page "/metronome"
@implements IDisposable
@inject IJSRuntime JS

<PageTitle>Metronome</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Metronome</MudText>


<MudStack Spacing="4">
    <MudNumericField @bind-Value="BeatsPerMinute" Label="Beats Per Minute (BPM)" Min="30" Max="300" Step="1"
                     Variant="Variant.Outlined" />

    <MudText Typo="Typo.subtitle1">Metrum (Beats per Bar)</MudText>
    <MudStack Row="true" Spacing="2">
        <MudNumericField @bind-Value="beatsPerBar" Label="Beats per Bar" Min="1" Step="1" Variant="Variant.Outlined" />
        <MudNumericField @bind-Value="noteValue" Label="Note Value" Min="1" Max="64" Step="1"
                         Variant="Variant.Outlined" />
    </MudStack>

    <MudStack Row="true" Spacing="2">
        @if (IsRunning)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Stop">Stop Metronome</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SetBpm">Update</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Start">Start Metronome</MudButton>
        }
    </MudStack>

    <MudText Typo="Typo.body1">Current Beat: @currentBeat</MudText>
</MudStack>

@code {
    private int BeatsPerMinute = 120;
    private int currentBeat = 1;
    private int beatsPerBar = 4;
    private int noteValue = 4; // Quarter note
    private DotNetObjectReference<Metronome>? _dotNetRef;
    private bool IsRunning = false;

    private async Task Start()
    {
        await JS.InvokeVoidAsync("metronome.start", BeatsPerMinute, beatsPerBar, noteValue);
        IsRunning = await JS.InvokeAsync<bool>("metronome.getIsRunning");
    }

    private async Task Stop()
    {
        await JS.InvokeVoidAsync("metronome.stop");
        IsRunning = await JS.InvokeAsync<bool>("metronome.getIsRunning");
    }

    private async Task SetBpm()
    {
        await JS.InvokeVoidAsync("metronome.setBpm", BeatsPerMinute, beatsPerBar, noteValue);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("metronome.setDotNetReference", _dotNetRef, beatsPerBar);
        }
    }

    // This method is called from JavaScript
    [JSInvokable]
    public async Task OnBeat(int beatNumber)
    {
        currentBeat = beatNumber;
        await InvokeAsync(StateHasChanged);
        // Blazor's synchronization context
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}