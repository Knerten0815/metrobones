@using System.ComponentModel.DataAnnotations
<MudDialog>
    <DialogContent>
        <p>Are you sure you want to delete section @(SectionTitle)?</p>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Error" OnClick="Submit">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter, Required]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string SectionTitle { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(result: true));

    private void Cancel() => MudDialog.Cancel();
}
