@page "/"
@implements IDisposable
@inject IJSRuntime JS

<PageTitle>Metronome</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Metronome</MudText>

<MudStack Spacing="4">
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SetBpm(-10)">-10</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SetBpm(-1)">-1</MudButton>
        <MudNumericField @bind-Value="_tempo" @bind-Value:after="UpdateMetronome" Label="BPM" Min="1"
                         Max="1000" Step="1" HideSpinButtons="true" Style="min-width: 2.5rem;" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SetBpm(1)">+1</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SetBpm(10)">+10</MudButton>
    </MudStack>

    <TimeSignaturePicker @bind-BeatsPerBar="_notesPerBar" @bind-BeatsPerBar:after="UpdateNotesPerBar"
                         @bind-NoteValue="_noteValue" @bind-NoteValue:after="UpdateMetronome" />

    <MudText Typo="Typo.caption">Beat Accenting</MudText>
    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceEvenly">
        @for (int i = 1; i <= _beatAccents.Length; i++)
        {
            var beat = i;
            <BeatButton BeatNumber="beat" IsCurrentBeat="(beat == _currentBeat)" BeatAccent="_beatAccents[beat - 1]"
                        BeatAccentChanged="(x) => SetBeatAccent(beat, x)" />
        }
    </MudStack>

    <MudStack Row="true" Spacing="2" Justify="Justify.SpaceEvenly">
        @if (_isRunning)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Stop">Stop</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Start">Start</MudButton>
        }
    </MudStack>
</MudStack>

@code {
    private int _tempo = 120;   // in BPM or quarter notes per minute
    private int _notesPerBar = 4;
    private int _noteValue = 4; // Quarter note
    private int _currentBeat = 1;
    private int[] _beatAccents = new int[]{ 1, 0, 0, 0 };
    private DotNetObjectReference<Metronome>? _dotNetRef;
    private bool _isRunning = false;

    private async Task SetBpm(int increment)
    {
        _tempo += increment;
        await UpdateMetronome();
    }

    private async Task SetBeatAccent(int beatNumber, int accent)
    {
        if (beatNumber >= 1 && beatNumber <= _notesPerBar)
        {
            _beatAccents[beatNumber - 1] = accent;
            await UpdateMetronome();
        }
    }

    private async Task Start()
    {
        await JS.InvokeVoidAsync("metronome.start", _tempo, _notesPerBar, _noteValue);
        _isRunning = await JS.InvokeAsync<bool>("metronome.getIsRunning");
    }

    private async Task Stop()
    {
        await JS.InvokeVoidAsync("metronome.stop");
        _isRunning = await JS.InvokeAsync<bool>("metronome.getIsRunning");
    }

    private async Task UpdateNotesPerBar()
    {
        _beatAccents = new int[_notesPerBar];
        _beatAccents[0] = 1;
        await UpdateMetronome();
    }

    private async Task UpdateMetronome()
    {
        await JS.InvokeVoidAsync("metronome.setBpm", _tempo, _notesPerBar, _noteValue, _beatAccents);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("metronome.setDotNetReference", _dotNetRef, _notesPerBar);
        }
    }

    // This method is called from JavaScript
    [JSInvokable]
    public async Task OnBeat(int beatNumber)
    {
        _currentBeat = beatNumber;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}