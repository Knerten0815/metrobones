@inherits Layout.MetronomePageBase

<MudStack Spacing=3 AlignItems=AlignItems.Center>
    <MudStack Row=true Spacing=1 AlignItems=AlignItems.Center>
        <MudSwitch Size=@Size.Large Color=@(_countInActive ? Color.Secondary : Color.Primary) @bind-Value=_countIn Label="Count in" />
        <MudNumericField @bind-Value=_countInBars Min=1 Max=10 Disabled=@(!_countIn) Class="input-center-text" Style="max-width: 3rem"/>
        <MudText> bars.</MudText>
    </MudStack>
    <MudExpansionPanels Class="mud-width-full">
        @for(int i = 0; i < Sections.Count; i++)
        {
            int index = i; // capture for closure
            <ClickTrackSection @bind-Section=Sections[index] CurrentSectionID=_currentSectionID StartClicktrack=StartClickTrack DeleteSection=DeleteSection/>
        }
    </MudExpansionPanels>

    <MudStack Row=true Justify=@Justify.SpaceAround>
        <MudIconButton OnClick=AddSection Icon="@Icons.Material.Filled.AddCircleOutline" aria-label="add section" />
    </MudStack>
</MudStack>

@code {
    private bool _countIn, _countInActive;
    private int _countInBars = 2;
    private int _countInBeats = 8;
    private int _currentSectionID = -1;
    private int _remainingBeats = -1;
    private List<Models.ClickTrackSection> Sections = new List<Models.ClickTrackSection>
        {
            new Models.ClickTrackSection (id: 1) { Title = "Intro", Length = 2, MetData = new MetronomeData(notesPerBar: 6) { Tempo = 140 }},
            new Models.ClickTrackSection (id: 2) { Title = "Verse", Length = 2 },
            new Models.ClickTrackSection (id: 3) { Title = "Chorus", Length = 2, MetData = new MetronomeData() { Tempo = 140 }}
        };

    private void AddSection()
    {
        int newID = Sections.Count > 0 ? Sections.Max(s => s.ID) + 1 : 1;
            Sections.Add(item: new Models.ClickTrackSection(newID));
        StateHasChanged();
    }

    private void DeleteSection(int id)
    {
        Sections.RemoveAll(s => s.ID == id);
        StateHasChanged();
    }

    private async Task StartClickTrack(Models.ClickTrackSection startSection)
    {
        if(startSection == null)
            return;
        
        _currentSectionID = startSection.ID;
        _remainingBeats = startSection.Length * startSection.MetData.NotesPerBar - 1;
        if(_countIn)
        {
            _countInActive = true;
            _countInBeats = _countInBars * startSection.MetData.NotesPerBar + 1;
            _remainingBeats += _countInBeats;
        }
        await Met.UpdateSettings(startSection.MetData);
        await Met.Start();
    }

    protected override async void OnStateChanged()
    {
        if (_remainingBeats > 0)
        {
            _remainingBeats--;
            _countInBeats--;
            if (_countInBeats <= 0)
                _countInActive = false;
        }
        else
        {
            int nextSectionIndex = Sections.FindIndex(s => s.ID == _currentSectionID) + 1;
            if (nextSectionIndex < Sections.Count)
            {
                var nextSection = Sections[nextSectionIndex];
                _currentSectionID = nextSection.ID;
                _remainingBeats = nextSection.Length * nextSection.MetData.NotesPerBar - 1;
                await Met.UpdateSettings(nextSection.MetData);
            }
            else
            {
                _currentSectionID = -1;
                _remainingBeats = -1;
                await Met.Stop();
            }
        }
        
        base.OnStateChanged();
    }
}