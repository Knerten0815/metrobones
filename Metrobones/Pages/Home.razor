@page "/"
@using System;
@using System.Threading;

<PageTitle>Home</PageTitle>

<MudText Typo="Typo.h6">Beat Test</MudText>
<MudStack Spacing=@Beat>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ButtonOnClick">@ButtonText</MudButton>

    <MudProgressCircular Rounded="true" Color="Color.Default" Value="@Value">
        <ChildContent>@(Beat)</ChildContent>
    </MudProgressCircular>
</MudStack>


@code {
    public int Beat { get; set; }
    public int Value { get { return Beat * 25; } }

    public string ButtonText { get; set; } = "Beat Me!";
    public int ButtonClicked { get; set; }

    void ButtonOnClick()
    {
        Beat += 1;
        if (Beat > 4)
        {
            Beat = 0;
        }
    }
}