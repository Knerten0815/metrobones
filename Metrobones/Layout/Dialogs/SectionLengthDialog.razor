@using System.ComponentModel.DataAnnotations
<MudDialog>
    <DialogContent>
        <MudStack Row=@true Spacing=4 Justify=@Justify.Center>
            <MudButton Variant=@Variant.Filled Color=@Color.Primary OnClick=@(() => IncrementLength(-1)) Size=@Size.Large>-</MudButton>
            <MudNumericField @bind-Value=Length T=int Min=1 Max=1000 Step=1 HideSpinButtons=@true Class="input-center-text" Style="font-size: 3rem;" />
            <MudButton Variant=@Variant.Filled Color=@Color.Primary OnClick=@(() => IncrementLength(1)) Size=@Size.Large>+</MudButton>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter, Required]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public int Length { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(result: Length));

    private void Cancel() => MudDialog.Cancel();

    private void IncrementLength(int increment)
    {
        if (Length + increment < 1 || Length + increment > 1000)
            return;

        Length += increment;
    }
}
