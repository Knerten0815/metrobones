    static readonly Dictionary<string, string> _pageTitles = new(StringComparer.OrdinalIgnoreCase)
    {
        [""] = "Click Tracks",
        ["metronome"] = "Metronome",
        ["setlists"] = "Set Lists",
    };

    protected override void OnInitialized()
    {
        _pageTitle = GetPageTitle(Navigation.Uri);
        Navigation.LocationChanged += OnLocationChanged;
    }

    void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _pageTitle = GetPageTitle(e.Location);
        // flip the pendulum logo on each page change for fun
        _currentLogoSvgText = _currentLogoSvgText == logoSvgText ? logoFlippedSvgText : logoSvgText;
        InvokeAsync(StateHasChanged);
    }

    string GetPageTitle(string uri)
    {
        var relativePath = Navigation.ToBaseRelativePath(uri).Trim('/');
        if(_pageTitles.TryGetValue(relativePath, out var title))
        {
            return title;
        }

        int trackID = int.Parse(Navigation.Uri.Split("=").Last());
        string trackTitle = TrackStore.GetAsync(trackID).Result?.Title ?? "Click Track";
        return trackTitle;
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}