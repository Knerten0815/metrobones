<MudText Typo=@Typo.caption>Time Signature</MudText>
<MudStack Row=@true Spacing=1 Justify=@Justify.Center>
    <MudSelect Value=@BeatsPerBar ValueChanged=@OnBeatsPerBarChanged T=int FitContent=@true Style="text-align: center;">
        @foreach (var beat in _beats)
        {
            <MudSelectItem Value=@beat>@beat</MudSelectItem>
        }
    </MudSelect>
    <MudText>/</MudText>
    <MudSelect Value=@NoteValue ValueChanged=@OnNoteValueChanged T=int FitContent=@true Style="text-align: center;">
        @foreach (var note in _notes)
        {
            <MudSelectItem Value=@note>@note</MudSelectItem>
        }
    </MudSelect>
</MudStack>

@code {
    [Parameter]
    public int BeatsPerBar { get; set; } = 4;
    [Parameter]
    public EventCallback<int> BeatsPerBarChanged { get; set; }
    [Parameter]
    public int NoteValue { get; set; } = 4;
    [Parameter]
    public EventCallback<int> NoteValueChanged { get; set; }

    private List<int> _beats = new();
    private int[] _notes = { 1, 2, 4, 8, 16 };

    protected override void OnInitialized()
    {
        base.OnInitialized();
        for (int i = 1; i <= 32; i++)
        {
            _beats.Add(i);
        }
    }

    private async Task OnBeatsPerBarChanged(int value)
    {
        BeatsPerBar = value;
        await BeatsPerBarChanged.InvokeAsync(value);
    }

    private async Task OnNoteValueChanged(int value)
    {
        NoteValue = value;
        await NoteValueChanged.InvokeAsync(value);
    }
}