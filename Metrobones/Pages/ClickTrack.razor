@page "/track"

@using System.ComponentModel.DataAnnotations
@inherits Layout.MetronomePageBase
@inject ClickTrackStore TrackStore
@inject NavigationManager Navigation

<MudStack Spacing=3 AlignItems=AlignItems.Center>
    <MudStack Row=true Spacing=1 AlignItems=AlignItems.Center>
        <MudSwitch Size=@Size.Large Color=@(_countInActive ? Color.Secondary : Color.Primary) @bind-Value=Track.CountIn Class="@(_countInActive ? "no-interact" : "")" Label="Count in" />
        <MudNumericField @bind-Value=Track.CountInBars Min=1 Max=10 Disabled=@(!Track.CountIn) Class="input-center-text" Style="max-width: 3rem"/>
        <MudText> bars.</MudText>
    </MudStack>
    @* <MudText>Remaining=@_remainingBeats Current=@Met.CurrentBeat</MudText> *@
    <MudExpansionPanels Class="mud-width-full">
        @for(int i = 0; i < Track.Sections.Count; i++)
        {
            int index = i; // capture for closure
            <ClickTrackSection Section=Track.Sections[index] SectionChanged=@SectionChanged CurrentSectionID=_currentSectionID StartClicktrack=StartClickTrack DeleteSection=DeleteSection/>
        }
    </MudExpansionPanels>

    <MudStack Row=true Justify=@Justify.SpaceAround>
        <MudIconButton OnClick=AddSection Size=@Size.Large Color=@Color.Primary Icon="@Icons.Material.Filled.AddCircleOutline" aria-label="add section" />
    </MudStack>
</MudStack>

@code {
    [Parameter, Required]
    public Models.ClickTrack Track { get; set; } = new Models.ClickTrack();
    private bool _countInActive;
    private int _countInBeats = 8;
    private int _currentSectionID = -1;
    private int _remainingBeats = -1;

    protected override async Task OnInitializedAsync()
    {
        int trackID = int.Parse(Navigation.Uri.Split("=").Last());
        Track = TrackStore.GetAsync(trackID).Result ?? new Models.ClickTrack();

        Met.StopCallback += ResetCountInActive;
    }

    private void ResetCountInActive()
    {
        _countInActive = false;
    }

    private async Task AddSection()
    {
        int newID = Track.Sections.Count > 0 ? Track.Sections.Max(s => s.ID) + 1 : 1;
        Track.Sections.Add(item: new Models.ClickTrackSection(newID));
        StateHasChanged();
        await TrackStore.UpdateAsync(Track);
    }

    private async Task DeleteSection(int id)
    {
        Track.Sections.RemoveAll(s => s.ID == id);
        StateHasChanged();
        await TrackStore.UpdateAsync(Track);
    }

    private async Task SectionChanged(Models.ClickTrackSection section)
    {
        int index = Track.Sections.FindIndex(s => s.ID == section.ID);
        if (index != -1)
        {
            Track.Sections[index] = section;
            StateHasChanged();
            await TrackStore.UpdateAsync(Track);
        }
    }

    private async Task StartClickTrack(Models.ClickTrackSection startSection)
    {
        if(startSection == null)
            return;
        
        _currentSectionID = startSection.ID;
        _remainingBeats = startSection.Length * startSection.MetData.NotesPerBar;

        if(Track.CountIn)
        {
            _countInActive = true;
            _countInBeats = Track.CountInBars * startSection.MetData.NotesPerBar;
            _remainingBeats += _countInBeats;
        }

        await Met.UpdateSettings(startSection.MetData);
        await Met.Start();
    }

    protected override async void OnStateChanged()
    {
        if (_remainingBeats > 1)
        {
            _remainingBeats--;
            _countInBeats--;
            if (_countInBeats <= 0)
                _countInActive = false;
        }
        else
        {
            _remainingBeats--;
            int nextSectionIndex = Track.Sections.FindIndex(s => s.ID == _currentSectionID) + 1;

            if (nextSectionIndex < Track.Sections.Count)
            {
                var nextSection = Track.Sections[nextSectionIndex];
                _currentSectionID = nextSection.ID;
                _remainingBeats = nextSection.Length * nextSection.MetData.NotesPerBar;
                await Met.UpdateSettings(nextSection.MetData);
            }
            else
            {
                _currentSectionID = -1;
                _remainingBeats = -1;
                await Met.Stop();
            }
        }
        
        base.OnStateChanged();
    }
}