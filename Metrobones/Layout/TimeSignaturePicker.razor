<MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Vertical="true">
    <MudSelect Value="BeatsPerBar" ValueChanged="OnBeatsPerBarChanged" T="int" Label="Time Signature" Dense="false">
        @foreach (var beat in _beats)
        {
            <MudSelectItem Value="beat">@beat</MudSelectItem>
        }
    </MudSelect>
    <MudSelect Value="NoteValue" ValueChanged="OnNoteValueChanged" T="int" Dense="false">
        @foreach (var note in _notes)
        {
            <MudSelectItem Value="note">@note</MudSelectItem>
        }
    </MudSelect>
</MudButtonGroup>

@code {
    [Parameter]
    public int BeatsPerBar { get; set; } = 4;
    [Parameter]
    public EventCallback<int> BeatsPerBarChanged { get; set; }
    [Parameter]
    public int NoteValue { get; set; } = 4;
    [Parameter]
    public EventCallback<int> NoteValueChanged { get; set; }

    List<int> _beats = new();
    int[] _notes = { 1, 2, 4, 8, 16, 32 };
    @* string[] _notesNames = { "Whole", "Half", "Quarter", "8th", "16th", "32nd", "64th" }; *@

    protected override void OnInitialized()
    {
        base.OnInitialized();
        for (int i = 1; i <= 64; i++)
        {
            _beats.Add(i);
        }
    }

    private async Task OnBeatsPerBarChanged(int value)
    {
        BeatsPerBar = value;
        await BeatsPerBarChanged.InvokeAsync(value);
    }

    private async Task OnNoteValueChanged(int value)
    {
        NoteValue = value;
        await NoteValueChanged.InvokeAsync(value);
    }
}