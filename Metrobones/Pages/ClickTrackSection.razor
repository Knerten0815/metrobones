@using System.ComponentModel.DataAnnotations
@inherits Layout.MetronomePageBase

<MudExpansionPanel Expanded=@_openSection ExpandedChanged=@OpenSection Disabled=@(Met.IsRunning && CurrentSectionID != Section.ID)>
    <TitleContent>
        <MudStack AlignItems=@AlignItems.Center Row="true">
            @if (_openSection)
            {
                <MudTextField @bind-Value=Section.Title @bind-Value:after=OnSectionChanged T="string" @onclick:stopPropagation @onkeydown:stopPropagation />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.DragHandle" Size=@Size.Small aria-label="drag" />
                <MudChip Variant="Variant.Text" Size=@Size.Small T="string">@(Section.Length)x</MudChip>
                <MudText>@Section.Title</MudText>
            }
        </MudStack>
    </TitleContent>

    <ChildContent><MudStack Spacing=4>                
        <MudStack Justify=@Justify.SpaceEvenly AlignItems=@AlignItems.Center Row="true">
            <MudChip Variant="Variant.Text" Color=@Color.Primary Size=@Size.Medium T="string">@(Section.Length) bars</MudChip>
            <MudChip Variant="Variant.Text" Color=@Color.Primary Size=@Size.Medium T="string">@(Section.MetData.NotesPerBar)/@(Section.MetData.NoteValue)</MudChip>
            <MudChip Variant="Variant.Text" Color=@Color.Primary Size=@Size.Medium T="string">@(Section.MetData.Tempo) bpm</MudChip>
        </MudStack>

        <BeatAccenting @bind-BeatAccents=Section.MetData.BeatAccents  @bind-BeatAccents:after=OnSectionChanged
                   CurrentBeat=Met.CurrentBeat NotesPerBar=Section.MetData.NotesPerBar/>

        <MudStack Justify=@Justify.Center AlignItems=@AlignItems.Center Row="true" Style="position:relative">
            @* TODO: Add remaining beats indicator. Maybe progress bar? *@
            <PlayButton OnPlay=OnPlaySection/>
            <MudIconButton OnClick=OnDeleteSection Color=@Color.Primary Icon="@Icons.Material.Outlined.Delete" Size=@Size.Medium
                            Disabled=@Met.IsRunning Style="position:absolute;right:0" aria-label="delete section" />
        </MudStack>

    </MudStack></ChildContent>
</MudExpansionPanel>


@code {
    [Parameter]
    public int CurrentSectionID { get; set; }

    [Parameter, Required]
    public required Models.ClickTrackSection Section {get; set;}

    [Parameter]
    public EventCallback<Models.ClickTrackSection> SectionChanged { get; set; }

    [Parameter]
    public EventCallback<int> DeleteSection{ get; set; }
    
    [Parameter]
    public EventCallback<Models.ClickTrackSection> StartClicktrack{ get; set; }

    private bool _openSection = true;

    protected override void OnParametersSet()
    {
        if (Met.IsRunning)
        {
            _openSection = CurrentSectionID == Section.ID;
        }
    }
    
    private void OpenSection(bool shouldOpen){
        if (Met.IsRunning)
        {
            _openSection = CurrentSectionID == Section.ID;
        }
        else
        {
            _openSection = shouldOpen;
        }
    }

    private async Task OnSectionChanged()
    {
        await SectionChanged.InvokeAsync(Section);
    }

    private async Task OnDeleteSection()
    {
        await DeleteSection.InvokeAsync(Section.ID);
    }

    private async Task OnPlaySection()
    {
        await StartClicktrack.InvokeAsync(Section);
    }
}