@page "/metronome"

@inherits Layout.MetronomePageBase

<PageTitle>Metronome</PageTitle>

<MudStack Spacing=4>
    <TempoPicker @bind-Tempo=Met.Data.Tempo @bind-Tempo:after=Met.UpdateSettings />

    <TimeSignaturePicker @bind-BeatsPerBar=Met.Data.NotesPerBar @bind-BeatsPerBar:after=Met.UpdateNotesPerBar
                         @bind-NoteValue=Met.Data.NoteValue @bind-NoteValue:after=Met.UpdateSettings />

    <BeatAccenting @bind-BeatAccents=Met.Data.BeatAccents @bind-BeatAccents:after=Met.UpdateSettings
                   CurrentBeat=Met.CurrentBeat NotesPerBar=Met.Data.NotesPerBar Label="Edit Accenting"/>

    <PlayButton OnPlay=Met.Start/>
</MudStack>

